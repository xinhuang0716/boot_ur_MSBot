# Copy this file to .env and fill in your values.
# .env is git-ignored and will never be committed.

# ---------- Azure Bot Credentials ----------
# Leave empty for local testing with Bot Framework Emulator.
# Required for cloud deployment via Azure Bot Service.
MicrosoftAppId=
MicrosoftAppPassword=

# ---------- LLM Backend ----------
# Default: local Ollama. Supports any OpenAI-compatible endpoint, e.g.:
#   Ollama        → http://localhost:11434
#   LM Studio     → http://localhost:1234
#   Remote Ollama → http://<your-host>:11434
OLLAMA_BASE_URL=http://localhost:11434

# Model name to use for /api/generate.
# Change this to match whichever model you have pulled in Ollama / LM Studio.
OLLAMA_MODEL=gemma3:4b

# ---------- Conversation History ----------
# Maximum number of messages kept in context (1 user + 1 assistant = 2).
# Default: 20 messages = 10 turns.
HISTORY_LIMIT=20

# ---------- Server ----------
# Bot HTTP server port (default: 3978).
BOT_PORT=3978